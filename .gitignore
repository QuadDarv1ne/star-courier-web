# ============================================================================
# StarCourier Web - .gitignore
# ============================================================================

# ========================
# ENVIRONMENT VARIABLES
# ========================
.env
.env.local
.env.*.local
.env.production.local

# ========================
# BACKEND (Python/FastAPI)
# ========================
venv/
.venv/
backend-venv/
__pycache__/
*.py[cod]
*$py.class
.Python
*.so
*.pyd
*.egg-info/
.eggs/
dist/
build/

# ========================
# FRONTEND (Node.js/Vue)
# ========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
dist/
.cache/
.vite/
.vitest/
.nuxt/
.eslintcache

# ========================
# IDE & EDITORS
# ========================
.vscode/
.idea/
*.code-workspace
*.iml
*.iws
*.ipr
*.swp
*.swo
*~

# ========================
# OS
# ========================
.DS_Store
._*
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ========================
# DATABASE
# ========================
*.db-shm
*.db-wal
*.sqlite-shm
*.sqlite-wal

# ========================
# LOGS & TEMP
# ========================
logs/
*.log
*.tmp
*.temp
*.bak

# ========================
# TESTING
# ========================
.pytest_cache/
.coverage
htmlcov/
.tox/
test-results/

# ========================
# DOCKER
# ========================
docker-volumes/
postgres_data/
docker-compose.override.yml
